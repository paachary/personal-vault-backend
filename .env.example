# MongoDB Configuration
MONGO_DB_HOST=localhost
MONGO_DB_PORT=27017
MONGO_DB_NAME=personal_vault
MONGO_COLLECTION_NAME=users
MONGO_MFA_COLLECTION_NAME=mfa_codes

# JWT Configuration
# Generate a strong secret: openssl rand -base64 64
ACCESS_TOKEN_SECRET=your_jwt_secret_here

# AES-256-GCM Encryption Key for sensitive data at rest
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=your_64_char_hex_key_here

# CORS Configuration (comma-separated list of allowed origins)
# Local dev (Next.js dev server): http://localhost:3006
# Local dev (Next.js production): http://localhost:3007
# Docker Compose: http://localhost:3007
# Production: set to your frontend domain, e.g. https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:3007
